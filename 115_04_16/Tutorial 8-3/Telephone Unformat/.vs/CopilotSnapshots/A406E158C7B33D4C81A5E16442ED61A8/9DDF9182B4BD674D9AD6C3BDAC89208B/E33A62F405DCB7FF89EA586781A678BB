        /// <summary>
        /// IsValidFormat 方法用於驗證輸入的電話號碼格式。
        /// 
        /// 此方法接受一個字串參數，並判斷該字串是否為
        /// 台灣電話號碼的正確格式，格式應為：(XXX)XXX-XXXX
        /// 
        /// 參數：
        ///   str - 待檢驗的電話號碼字串
        /// 
        /// 返回值：
        ///   若字串格式正確，返回 true；否則返回 false
        /// </summary>
        private bool IsValidFormat(string str)
        {
           if (str.Length != 14)
            {
                return false;
            }
            if (str[0] != '(' || str[4] != ')' || str[9] != '-')
            {
                return false;
            }
            for (int i = 1; i <= 2; i++)
            {
                if (!char.IsDigit(str[i]))
                {
                    return false;
                }
            }
            for (int i = 5; i <= 8; i++)
            {
                if (!char.IsDigit(str[i]))
                {
                    return false;
                }
            }
            for (int i = 10; i <= 13; i++)
            {
                if (!char.IsDigit(str[i]))
                {
                    return false;
                }
            }
            return true;
        }

        /// <summary>
        /// Unformat 方法用於移除電話號碼的格式符號。
        /// 
        /// 此方法接受一個字串引用參數，該參數應包含格式為
        /// (XX) XXXX-XXXX 的電話號碼。
        /// 方法將移除括號和連字號，使電話號碼成為純數字形式。
        /// 
        /// 參數：
        ///   str - 待格式化的電話號碼字串（以參考方式傳遞，方法會直接修改原字串）
        /// </summary>
        private void Unformat(ref string str)
        {
            //str = str.Substring(1, 2) + str.Substring(5, 4) + str.Substring(10, 4);
            str = str.Remove(0, 1); // 移除第一個括號
            str = str.Remove(2, 1); // 移除第二個括號
            str = str.Remove(2, 1); // 移除連字號
            str = str.Remove(6, 1); // 移除連字號
        }

        /// <summary>
        /// unformatButton_Click 事件處理方法
        /// 
        /// 當用戶點擊「移除格式」按鈕時觸發此事件。
        /// 方法將驗證輸入的電話號碼格式，若格式正確則移除格式符號並顯示結果；
        /// 若格式不正確則提示用戶。
        /// </summary>
        private void unformatButton_Click(object sender, EventArgs e)
        {
            string input = numberTextBox.Text;
            if (IsValidFormat(input))
            {
                Unformat(ref input);
                numberTextBox.Text = input;
            }
            else
            {
                MessageBox.Show("電話號碼格式不正確，請輸入符合格式 (XX) XXXX-XXXX 的電話號碼。");
            }
        }

